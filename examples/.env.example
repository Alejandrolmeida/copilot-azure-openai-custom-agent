# Copy this file to .env and fill it with your own values.
# Never commit .env.

# Azure OpenAI / Azure AI Foundry OpenAI-compatible endpoint.
# Common Azure OpenAI v1 shape:
# https://YOUR-AZURE-OPENAI-RESOURCE.openai.azure.com/openai/v1/
AZURE_OPENAI_BASE_URL=https://YOUR-AZURE-OPENAI-RESOURCE.openai.azure.com/openai/v1/

# Deployment name configured in Azure OpenAI / Azure AI Foundry.
AZURE_OPENAI_MODEL=YOUR_DEPLOYMENT_NAME

# Local testing only. Prefer a secret manager for shared environments.
AZURE_OPENAI_API_KEY=YOUR_API_KEY

# Recommended for reasoning-capable models. This is output budget, not input context.
AZURE_OPENAI_MAX_COMPLETION_TOKENS=16384

# Optional: if you load the API key from Azure Key Vault in the wrapper.
AZURE_KEYVAULT_NAME=YOUR_KEY_VAULT_NAME
AZURE_KEYVAULT_SECRET_NAME=azure-openai-api-key
AZURE_SUBSCRIPTION_ID=YOUR_SUBSCRIPTION_ID

# GitHub Copilot CLI BYOK mapping.
# Use a well-known model ID so Copilot CLI can apply suitable agent settings.
COPILOT_PROVIDER_MODEL_ID=gpt-5.5
COPILOT_PROVIDER_MAX_PROMPT_TOKENS=1000000
COPILOT_PROVIDER_MAX_OUTPUT_TOKENS=16384
