# Copy this file to .env on a new machine when you want to bootstrap from Azure Key Vault.
# This file contains no API key. The wrapper reads the key and runtime settings from Key Vault.

# Azure Key Vault containing the portable configuration secret and API key secret.
AZURE_KEYVAULT_NAME=YOUR_KEY_VAULT_NAME

# JSON secret created by scripts/export-current-config-to-keyvault.sh.
AZURE_KEYVAULT_CONFIG_SECRET_NAME=copilot-azure-config

# Optional but recommended when you have access to multiple subscriptions.
AZURE_SUBSCRIPTION_ID=YOUR_SUBSCRIPTION_ID